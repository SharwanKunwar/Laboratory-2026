# API base URL (optional; default http://localhost:8080/api)
# VITE_API_URL=http://localhost:8080/api

# Google Sign-In: create OAuth 2.0 client at https://console.cloud.google.com/
# Use "Web application" and add authorized JavaScript origins (e.g. http://localhost:5173)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Facebook Login: create app at https://developers.facebook.com/
# Add "Facebook Login" product and use the App ID
VITE_FACEBOOK_APP_ID=your-facebook-app-id
